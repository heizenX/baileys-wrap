{
	"name": "baileys-wrap",
	"version": "0.0.0",
	"description": "A strongly-typed abstraction layer over Baileys that maps raw WhatsApp events into a clean, predictable domain API.",
	"keywords": [
		"whatsapp",
		"baileys",
		"bot"
	],
	"author": {
		"name": "Dante VR",
		"email": "softwareprogramando@gmail.com"
	},
	"homepage": "https://github.com/heizenX/baileys-wrap#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/heizenX/baileys-wrap.git"
	},
	"bugs": {
		"url": "https://github.com/heizenX/baileys-wrap/issues"
	},
	"license": "MIT",
	"type": "module",
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"import": "./lib/index.js",
			"types": "./lib/index.d.ts"
		}
	},
	"files": [
		"lib/"
	],
	"scripts": {
		"start": "tsx tests/main.ts",
		"dev": "tsx watch tests/main.ts",
		"build": "tsdown",
		"format": "prettier .",
		"lint": "eslint . --max-warnings 0",
		"prepare": "husky",
		"test": "vitest",
		"tsc": "tsc"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"dependencies": {
		"@hapi/boom": "10.0.1"
	},
	"devDependencies": {
		"@cacheable/node-cache": "^2.0.2",
		"@eslint/js": "9.39.3",
		"@release-it/conventional-changelog": "10.0.5",
		"@types/node": "24.11.0",
		"@types/pg": "^8.18.0",
		"@types/qrcode-terminal": "^0.12.2",
		"@vitest/coverage-v8": "4.0.18",
		"@vitest/eslint-plugin": "1.6.9",
		"@whiskeysockets/baileys": "7.0.0-rc.9",
		"console-fail-test": "0.6.1",
		"eslint": "9.39.3",
		"husky": "9.1.7",
		"jiti": "2.6.1",
		"lint-staged": "16.3.1",
		"pg": "^8.19.0",
		"pino": "10.3.1",
		"pino-pretty": "^13.1.3",
		"prettier": "3.7.4",
		"qrcode-terminal": "0.12.0",
		"release-it": "19.0.6",
		"tsdown": "0.20.3",
		"tsx": "^4.21.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.56.1",
		"vitest": "4.0.18"
	},
	"engines": {
		"node": ">=20.19.0"
	},
	"peerDependencies": {
		"@cacheable/node-cache": ">=2.0.0",
		"@whiskeysockets/baileys": ">=7.0.0-rc.9",
		"pino": ">10.0.0"
	},
	"peerDependenciesMeta": {
		"@cacheable/node-cache": {
			"optional": true
		},
		"pino": {
			"optional": true
		}
	},
	"packageManager": "pnpm@10.30.3",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@whiskeysockets/baileys",
			"baileys",
			"esbuild",
			"protobufjs",
			"sharp"
		]
	}
}
